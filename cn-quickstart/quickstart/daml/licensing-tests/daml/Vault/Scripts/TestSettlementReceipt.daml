-- | Tests for SettlementReceipt template.
module Vault.Scripts.TestSettlementReceipt where

import Daml.Script
import DA.Optional (isSome)
import Vault.SettlementReceipt (SettlementReceipt(..))

test_create_receipt : Script ()
test_create_receipt = do
  proposer <- allocateParty "SME"
  accepter <- allocateParty "Financier"
  now <- getTime
  cid <- submitMulti [proposer, accepter] [] do
    createCmd SettlementReceipt with
      proposer = proposer
      accepter = accepter
      amount = 5000.0
      currency = "CC"
      timestamp = now
      note = Some "test"
  -- Both signatories should be able to fetch the receipt
  Some _ <- queryContractId proposer cid
  Some _ <- queryContractId accepter cid
  return ()