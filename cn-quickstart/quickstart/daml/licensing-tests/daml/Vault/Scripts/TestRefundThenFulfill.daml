-- | After a Refund (consuming), the commitment is archived. A subsequent
-- Fulfill on the same contract must fail.
module Vault.Scripts.TestRefundThenFulfill where

import Daml.Script
import DA.Time
import Vault.CommitmentProposal (CommitmentProposal(..), AcceptProposal(..))
import Vault.CommitmentContract (CommitmentContract(..), Refund(..), Fulfill(..))

test_refund_then_fulfill_fails : Script ()
test_refund_then_fulfill_fails = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  now <- getTime
  let deadline = addRelTime now (seconds 1)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 100.0
    currency = "CC"
    description = "T4: refund then fulfill"
    workflow = "supply-chain-finance"
    deadline = deadline
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  -- Wait past deadline, then refund (consuming — archives the commitment)
  passTime (seconds 2)
  submit proposer $ exerciseCmd contractCid
    (Refund with actor = proposer)
  -- Fulfill on the archived contract must fail
  submitMustFail accepter $ exerciseCmd contractCid (Fulfill with
    fulfillmentNote = "should fail after refund"
    allocationCid = None)
  return ()