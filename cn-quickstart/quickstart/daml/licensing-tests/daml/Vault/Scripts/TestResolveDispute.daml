-- | Tests for ResolveDispute choice (thirdParty decides).
module Vault.Scripts.TestResolveDispute where

import Daml.Script
import DA.Time
import Vault.CommitmentProposal (CommitmentProposal(..), AcceptProposal(..))
import Vault.CommitmentContract (CommitmentContract(..), RaiseDispute(..), DisputeCase(..), ResolveDispute(..))

test_thirdparty_resolves : Script ()
test_thirdparty_resolves = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  dso <- allocateParty "DSO"
  now <- getTime
  let deadline = addRelTime now (seconds 6000)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 100.0
    currency = "CC"
    description = "Supply chain finance INV-2026-005"
    workflow = "supply-chain-finance"
    deadline = deadline
    instrumentAdmin = dso
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  -- thirdParty authorizes the disclosure (Canton divulge consent).
  disputeCid <- submitMulti [proposer, accepter, thirdParty] [] $ exerciseCmd contractCid (RaiseDispute with reason = "unpaid"; actor = proposer)
  submit thirdParty $ exerciseCmd disputeCid (ResolveDispute with ruling = "proposer")
  result <- queryContractId thirdParty disputeCid
  case result of
    None -> return () -- DisputeCase archived, resolution DisclosedRecord created
    Some _ -> assertMsg "DisputeCase should be archived after resolution" False
  return ()