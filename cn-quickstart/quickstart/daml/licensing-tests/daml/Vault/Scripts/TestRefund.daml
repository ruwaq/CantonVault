-- | Tests for Refund choice (deadline-gated).
module Vault.Scripts.TestRefund where

import Daml.Script
import DA.Time
import DA.Assert (assertMsg)
import Vault.CommitmentProposal (CommitmentProposal(..), AcceptProposal(..))
import Vault.CommitmentContract (CommitmentContract(..), Refund(..))

test_refund_blocked_before_deadline : Script ()
test_refund_blocked_before_deadline = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  now <- getTime
  let deadline = addRelTime now (seconds 9999999)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 100.0
    currency = "CC"
    description = "Supply chain finance INV-2026-003"
    workflow = "supply-chain-finance"
    deadline = deadline
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  -- Refund before deadline must fail (symbolic path: allocationCid = None).
  submitMustFail proposer $ exerciseCmd contractCid
    (Refund with actor = proposer)
  Some _ <- queryContractId proposer contractCid
  assertMsg "Contract should still be active after failed refund" True
  return ()

test_refund_allowed_after_deadline : Script ()
test_refund_allowed_after_deadline = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  now <- getTime
  let deadline = addRelTime now (seconds 1)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 100.0
    currency = "CC"
    description = "Supply chain finance INV-2026-004"
    workflow = "supply-chain-finance"
    deadline = deadline
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  passTime (seconds 2)
  receiptCid <- submit proposer $ exerciseCmd contractCid
    (Refund with actor = proposer)
  -- Refund archives the commitment (consuming) and creates a SettlementReceipt.
  result <- queryContractId proposer contractCid
  case result of
    None -> return ()
    Some _ -> assertMsg "Commitment should be archived after refund" False
  receiptOpt <- queryContractId proposer receiptCid
  case receiptOpt of
    None -> assertMsg "Refund should create a SettlementReceipt" False
    Some receipt -> assertMsg "Receipt amount should match commitment" (receipt.amount == 100.0)
  return ()