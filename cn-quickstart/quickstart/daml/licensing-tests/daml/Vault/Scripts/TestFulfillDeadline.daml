-- | Tests for Fulfill behavior around the deadline boundary.
-- T1: Decision pending — should Fulfill be blocked after deadline like Refund is?
-- Currently Fulfill has NO deadline guard (unlike Refund), so it succeeds even after
-- the deadline passes. This test DOCUMENTS the current behavior; the decision whether
-- to add a guard is recorded in docs/DECISION-LOG.md.
module Vault.Scripts.TestFulfillDeadline where

import Daml.Script
import DA.Time
import Vault.CommitmentProposal (CommitmentProposal(..), AcceptProposal(..))
import Vault.CommitmentContract (CommitmentContract(..), Fulfill(..))
import Vault.SettlementReceipt (SettlementReceipt(..))

-- | Confirm that Fulfill works before the deadline (baseline, same as TestFulfill).
test_fulfill_before_deadline : Script ()
test_fulfill_before_deadline = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  dso <- allocateParty "DSO"
  now <- getTime
  let deadline = addRelTime now (seconds 999999)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 100.0
    currency = "CC"
    description = "T1: fulfill before deadline"
    workflow = "supply-chain-finance"
    deadline = deadline
    instrumentAdmin = dso
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  -- Fulfill well before deadline
  receiptCid <- submit accepter $ exerciseCmd contractCid (Fulfill with
    fulfillmentNote = "fulfilled on time"
    allocationCid = None)
  receipts <- query @SettlementReceipt proposer
  assertMsg "Proposer must see receipt after timely Fulfill" (not (null receipts))
  return ()

-- | T1 RESOLVED: Fulfill now has a deadline guard (assertMsg "Cannot fulfill
-- after deadline"). This test verifies that Fulfill is correctly BLOCKED
-- after the deadline passes, matching the Refund guard symmetry.
test_fulfill_after_deadline_fails : Script ()
test_fulfill_after_deadline_fails = do
  proposer <- allocateParty "Supplier"
  accepter <- allocateParty "Financier"
  thirdParty <- allocateParty "Buyer"
  dso <- allocateParty "DSO"
  now <- getTime
  let deadline = addRelTime now (seconds 1)
  proposalCid <- submit proposer $ createCmd CommitmentProposal with
    proposer = proposer
    accepter = accepter
    thirdParty = thirdParty
    amount = 200.0
    currency = "CC"
    description = "T1: fulfill after deadline (now blocked)"
    workflow = "supply-chain-finance"
    deadline = deadline
    instrumentAdmin = dso
  contractCid <- submit accepter $ exerciseCmd proposalCid AcceptProposal
  -- Wait past the deadline
  passTime (seconds 2)
  -- Fulfill after deadline MUST fail (guard added in hardening)
  submitMustFail accepter $ exerciseCmd contractCid (Fulfill with
    fulfillmentNote = "should fail after deadline"
    allocationCid = None)
  return ()