BACKEND_PORT: "${BACKEND_PORT}"
REGISTRY_BASE_URI: "http://splice:5012"
LEDGER_HOST: "canton"
LEDGER_PORT: "3${PARTICIPANT_LEDGER_API_PORT_SUFFIX}"
POSTGRES_HOST: "${DB_SERVER}"
POSTGRES_PORT: "${DB_PORT}"
POSTGRES_DATABASE: "pqs-app-provider"
POSTGRES_USERNAME: "${DB_USER}"
POSTGRES_PASSWORD: "${DB_PASSWORD}"
SPRING_PROFILES_ACTIVE: "${AUTH_MODE},dev"
TEST_MODE: "${TEST_MODE}"

# CantonVault demo parties — populate the UI party selectors (GET /vault/parties).
# Resolved from the docker-compose env files (e.g. quickstart/.env.local). Empty by
# default so the selector falls back to free-text entry when not configured.
VAULT_PROPOSER_PARTY: "${VAULT_PROPOSER_PARTY}"
VAULT_ACCEPTER_PARTY: "${VAULT_ACCEPTER_PARTY}"
VAULT_THIRDPARTY_PARTY: "${VAULT_THIRDPARTY_PARTY}"
CORS_ALLOWED_ORIGINS: "${CORS_ALLOWED_ORIGINS}"

#if observability is not enabled we still have trace-id in the logs
OTEL_TRACES_EXPORTER: none
OTEL_LOGS_EXPORTER: none
OTEL_METRICS_EXPORTER: none
JAVA_OPTS: "-javaagent:/otel-agent.jar -Dotel.instrumentation.logback-appender.experimental-log-attributes=true -Dotel.instrumentation.logback-appender.experimental.capture-key-value-pair-attributes=true"