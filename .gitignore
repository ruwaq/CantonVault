# Secrets — NEVER commit files containing credentials, tokens, or keys.
# Docker env files (oauth2.env, keycloak.env, etc.) are protected by the
# cn-quickstart/** blanket rule above. Only explicitly whitelisted env files
# (e.g. app.env with variable references, not literals) are tracked.
*.pem
*.key
.env
.env.*
*.env
.envrc
.envrc.*
*.envrc
!docs/**/.env.example

